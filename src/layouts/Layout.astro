---
import '../styles/global.css';
import CookieConsent from '../components/CookieConsent';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Astro, React, Tailwind v4, GSAP, Lenis Scaffold" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-slate-950 text-slate-50 antialiased min-h-screen selection:bg-primary/30">
    <slot />
    <CookieConsent client:load />
    
    <script>
      import Lenis from 'lenis';
      import gsap from 'gsap';
      import ScrollTrigger from 'gsap/ScrollTrigger';

      // Register ScrollTrigger
      gsap.registerPlugin(ScrollTrigger);

      // Initialize Lenis
      const lenis = new Lenis({
        autoRaf: true,
      });

      // Expose globally
      (window as any).lenis = lenis;

      // Sync ScrollTrigger with Lenis's scroll updates
      lenis.on('scroll', ScrollTrigger.update);

      // Add Lenis's requestAnimationFrame (raf) to GSAP's ticker
      gsap.ticker.add((time) => {
        lenis.raf(time * 1000);
      });

      // Disable GSAP's lag smoothing to prevent conflicts with Lenis
      gsap.ticker.lagSmoothing(0);

      // Handle click events on anchor links for smooth scrolling
      document.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const anchor = target.closest('a');
        if (!anchor) return;

        const href = anchor.getAttribute('href');
        if (!href) return;

        // Check if it is a hash link
        if (href.includes('#')) {
          const [pathname, hash] = href.split('#');
          const currentPath = window.location.pathname;
          
          // Normalize paths
          const normalizedPath = pathname === '' || pathname === '/' ? '/' : pathname;
          const normalizedCurrent = currentPath === '' || currentPath === '/' ? '/' : currentPath;

          if (normalizedPath === normalizedCurrent) {
            e.preventDefault();
            const targetElement = document.getElementById(hash);
            if (targetElement) {
              lenis.scrollTo(targetElement, {
                duration: 1.5,
                easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)), // smooth cubic ease out
              });
            } else if (hash === 'home' || hash === '') {
              lenis.scrollTo(0, {
                duration: 1.5,
                easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
              });
            }
          }
        }
      });

      // Handle scroll to hash on initial page load
      if (window.location.hash) {
        setTimeout(() => {
          const targetElement = document.getElementById(window.location.hash.substring(1));
          if (targetElement) {
            lenis.scrollTo(targetElement, {
              duration: 1.5,
              easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
            });
          }
        }, 300); // 300ms delay to ensure DOM and GSAP are fully ready
      }
    </script>
  </body>
</html>
